# Test de Perform Script con vinculo
# Usa nombres de scripts que aparecen en tu Gen_Presentacion_Ir.fmscript
Set Variable [$x = 1]
# Perform Script con script y parametro
Perform Script ["Gen_Comprobar"; GetValue( $PG ; 1 )]
# Perform Script con script y sin parametro
Perform Script ["SecIte_Ordenar_Items"]
# Perform Script con script y calculo de parametro
Perform Script ["Gen_Presentacion_FiltrarDel"; "¶1"]
# Perform Script on Server (mismo formato)
Perform Script on Server ["Gen_Comprobar"; GetValue( $PG ; 1 )]
# Fin del test
