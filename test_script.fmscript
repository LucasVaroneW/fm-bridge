# Round-trip test — fm-bridge
# Steps used: Set Variable, Loop, Exit Loop If, End Loop, Show All Records, Perform Script
Set Variable [$counter = 0]
Set Variable [$mensaje = "Iteración"]
Loop
  Set Variable [$counter = $counter + 1]
  Exit Loop If [$counter >= 5]
End Loop
# Listo el bucle
Show All Records
Perform Script [Get(ScriptName)]
# Fin del test
